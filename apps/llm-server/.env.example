# LLM Server Configuration
LLM_SERVER_HOST=localhost
LLM_SERVER_PORT=8000
LLM_SERVER_WORKERS=4

# Model Paths and Configuration
MODELS_DIR=./models
MODELS_CACHE_DIR=./models/cache
MAX_CONCURRENT_REQUESTS=10

# M1 Ultra Specific Settings
METAL_ENABLED=true
GPU_LAYERS=-1
CONTEXT_SIZE=8192
BATCH_SIZE=512
THREADS=8

# Model Specific Settings
ROUTER_MODEL_PATH=./models/qwen2-1_5b-instruct-q6_k.gguf
ARCHITECT_MODEL_PATH=./models/qwen2_5-32b-instruct-q6_k.gguf
CODER_PRIMARY_MODEL_PATH=./models/qwen2_5-coder-7b-instruct-q6_k.gguf
CODER_SECONDARY_MODEL_PATH=./models/deepseek-coder-v2-lite-instruct-q6_k.gguf
QA_CHECKER_MODEL_PATH=./models/qwen2_5-14b-instruct-q6_k.gguf
DEBUGGER_MODEL_PATH=./models/deepseek-coder-v2-lite-instruct-q6_k.gguf

# Memory Management
MAX_MEMORY_USAGE=70  # Percentage of total RAM (128GB)
MEMORY_WARNING_THRESHOLD=80
MEMORY_CRITICAL_THRESHOLD=90

# Monitoring
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
LOG_LEVEL=INFO
LOG_FILE=./logs/llm-server.log

# Development
DEBUG=false
RELOAD=false
TESTING=false

# HuggingFace (for model downloads)
HF_HOME=./models/huggingface
HF_TOKEN=your_token_here